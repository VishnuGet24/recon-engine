# Copy to .env (next to docker-compose.yml) and customize.
#
# MySQL
MYSQL_ROOT_PASSWORD=recon_root_password
MYSQL_DATABASE=recon_db
MYSQL_USER=recon_user
MYSQL_PASSWORD=recon_password
MYSQL_HOST_PORT=3307
#
# Backend
APP_ENV=production
FLASK_DEBUG=0
SECRET_KEY=change-this-in-production
JWT_SECRET=change-this-in-production
ENABLE_DB_CREATE_ALL=0
DB_AUTO_INIT=1
WAIT_FOR_DB=1
WAIT_FOR_DB_TIMEOUT_SECONDS=60
WAIT_FOR_DB_INTERVAL_SECONDS=2
GUNICORN_WORKERS=2
GUNICORN_THREADS=4
#
# Cookies/CORS
SESSION_COOKIE_SECURE=0
CORS_ORIGINS=http://localhost,http://127.0.0.1
#
# Nginx
NGINX_PORT=80
