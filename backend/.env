# Flask
FLASK_APP=app.py
FLASK_DEBUG=0
SECRET_KEY=change-this-to-a-64-char-random-secret

# Session
SESSION_COOKIE_SECURE=0
SESSION_COOKIE_SAMESITE=Lax
SESSION_TTL_MINUTES=30

# Database (MySQL)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=ROOT
DB_NAME=scanner_db

# Optional direct SQLAlchemy URI (overrides DB_* fields)
# DATABASE_URL=mysql+pymysql://root:change-me@127.0.0.1:3306/recon_db?charset=utf8mb4

# Scanner safety
ALLOW_PRIVATE_TARGETS=0

# bcrypt cost factor
BCRYPT_LOG_ROUNDS=12

# Optional: create missing tables on startup (for local development)
ENABLE_DB_CREATE_ALL=0

DATABASE_URL=sqlite:///recon_dev.db
ENABLE_DB_CREATE_ALL=1
