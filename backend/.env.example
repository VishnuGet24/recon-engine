# Flask
FLASK_APP=app.py
FLASK_DEBUG=0
APP_ENV=development
SECRET_KEY=change-this-to-a-64-char-random-secret

# Session / CSRF
SESSION_COOKIE_SECURE=0
SESSION_COOKIE_SAMESITE=Lax
SESSION_TTL_MINUTES=30
CSRF_HEADER_NAME=X-CSRF-Token
CSRF_TOKEN_BYTES=32

# CORS (comma separated). Keep frontend and API hostnames consistent
# (use localhost for both, or 127.0.0.1 for both) to avoid browser cookie isolation.
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Database (MySQL)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=ROOT
DB_NAME=scanner_db

# Optional direct SQLAlchemy URI (overrides DB_* fields)
# DATABASE_URL=mysql+pymysql://root:ROOT@127.0.0.1:3306/scanner_db?charset=utf8mb4

# SQLAlchemy pool
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=280

# Scanner safety
ALLOW_PRIVATE_TARGETS=0

# bcrypt cost factor
BCRYPT_LOG_ROUNDS=12

# Request rate limiting
LOGIN_RATE_LIMIT=10
LOGIN_RATE_WINDOW_SEC=300
SCAN_RATE_LIMIT=30
SCAN_RATE_WINDOW_SEC=300

# Optional: create missing tables on startup (for local development)
ENABLE_DB_CREATE_ALL=0

# Logging
LOG_LEVEL=INFO
LOG_DIR=./logs
# LOG_CONFIG_FILE=./logging.conf
